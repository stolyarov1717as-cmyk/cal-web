# ===== Supabase =====
# Все переменные с префиксом VITE_ нужны на этапе СБОРКИ (build-time):
# Vite вшивает их в JS-бандл при `vite build`. На runtime их менять бессмысленно
# — нужно пересобрать образ. В Coolify пометь обе галочкой "Available at Buildtime".

# URL твоего Supabase-проекта (build-time)
VITE_SUPABASE_URL=

# Публичный anon-ключ Supabase (build-time)
# Это публичный ключ, безопасный для клиента — RLS-политики защищают данные на стороне БД.
VITE_SUPABASE_ANON_KEY=
